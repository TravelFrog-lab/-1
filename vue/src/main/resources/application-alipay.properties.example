# ========== 支付宝沙箱配置（必填） ==========
# 在支付宝开放平台 -> 开发者中心 -> 沙箱环境 中获取并填写下面几项即可。

# 沙箱应用 AppID
alipay.app-id=你的沙箱AppID

# 应用私钥（RSA2）：你生成的密钥对中的私钥，可去掉 -----BEGIN/END----- 和换行，也可保留
alipay.private-key=你的应用私钥

# 支付宝公钥（沙箱页面里的「支付宝公钥」，不是「应用公钥」）
alipay.alipay-public-key=支付宝公钥

# 沙箱网关（一般不需改）
alipay.gateway-url=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# 支付成功后浏览器同步跳转的地址（可填前端地址，如 http://localhost:8080/#/home）
alipay.return-url=http://localhost:8080

# 支付结果异步通知地址（你后端的接口 URL，需公网可访问；本地调试可先不填或填内网穿透地址）
# alipay.notify-url=http://你的公网域名/api/alipay/notify
